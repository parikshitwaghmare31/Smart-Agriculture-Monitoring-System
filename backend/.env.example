# App
APP_NAME=Smart Agriculture Monitoring API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=smart_agriculture
SENSOR_COLLECTION=sensor_readings
PREDICTION_COLLECTION=predictions

# MQTT
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_TOPIC=farm/sensors
MQTT_CLIENT_ID=smart-agri-backend
MQTT_ENABLED=true

# ML
MODEL_PATH=/app/ml/models/irrigation_model.pkl

# CORS (comma separated, or * for all)
CORS_ORIGINS=*
