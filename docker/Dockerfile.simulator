# --- ESP32 MQTT Sensor Simulator ---
FROM python:3.11-slim

WORKDIR /app

COPY mqtt-simulator/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY mqtt-simulator/simulator.py /app/simulator.py

ENV PYTHONUNBUFFERED=1

CMD ["python", "simulator.py", "--devices", "3", "--interval", "5"]
